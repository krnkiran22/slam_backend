# Copy to .env and fill in values
# On Railway, DATABASE_URL and REDIS_URL are injected automatically

# --- Local dev: use the public Railway proxy URLs ---
DATABASE_URL=postgresql://postgres:<password>@hopper.proxy.rlwy.net:49949/railway

# --- Railway internal (auto-set by Railway, do not change) ---
# DATABASE_URL=postgresql://postgres:<password>@postgres.railway.internal:5432/railway

REDIS_URL=redis://default:<password>@hopper.proxy.rlwy.net:<port>
# Railway internal: redis://default:<password>@redis.railway.internal:6379

SECRET_KEY=generate-with-python-secrets-token-hex-32
FRONTEND_URL=https://your-app.vercel.app
